{
  "name": "sk-rosa",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev --host 0.0.0.0 --port 4321",
    "dev:astro": "astro dev --host 0.0.0.0 --port 4321",
    "directus:up": "docker-compose -f directus/docker-compose.yml up -d",
    "directus:down": "docker-compose -f directus/docker-compose.yml down",
    "directus:bootstrap": "node scripts/directus/bootstrap-directus-poc.js",
    "directus:pull": "node scripts/directus/pull-directus-cache.js",
    "build": "npm run build:astro:production",
    "build:astro": "astro build",
    "check:astro:services": "node scripts/astro/check-service-output.js",
    "check:astro:blog": "node scripts/astro/check-blog-output.js",
    "check:astro:production": "node scripts/astro/check-production-output.js",
    "check:astro:sitemap": "node scripts/astro/check-sitemap-output.js",
    "check:astro:aeo": "node scripts/astro/check-aeo-metadata.js",
    "measure:astro:generation": "node scripts/astro/measure-generation.js",
    "build:astro:production": "bash scripts/astro/build-production.sh",
    "deploy": "npm run deploy:sprint",
    "deploy:hosting": "npm run build:astro:production",
    "deploy:sprint": "bash scripts/deploy.sh",
    "preview": "astro preview --host 0.0.0.0 --port 4322",
    "preview:astro": "astro preview --host 0.0.0.0 --port 4322",
    "serve": "bash scripts/serve.sh",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint src/scripts/**/*.js",
    "lint:css": "stylelint \"src/styles/**/*.scss\"",
    "lint:fix": "npm run lint:js:fix && npm run lint:css:fix",
    "lint:js:fix": "eslint src/scripts/**/*.js --fix",
    "lint:css:fix": "stylelint \"src/styles/**/*.scss\" --fix",
    "format": "prettier --write \"src/**/*.{js,html,json,scss}\"",
    "fix": "npm run lint && npm run lint:fix && npm run format",
    "format:check": "prettier --check \"src/**/*.{js,html,json,scss}\"",
    "analyze:css": "node analyze-css.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/react": "^5.0.5",
    "@eslint/js": "^9.39.1",
    "astro": "^6.3.3",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "sass": "^1.90.0",
    "stylelint": "^16.26.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vite-plugin-static-copy": "^3.1.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "framer-motion": "^12.39.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
