{
  "name": "sk-rosa",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:astro": "astro dev --host 0.0.0.0 --port 4321",
    "directus:up": "docker-compose -f directus/docker-compose.yml up -d",
    "directus:down": "docker-compose -f directus/docker-compose.yml down",
    "directus:bootstrap": "node scripts/directus/bootstrap-directus-poc.js",
    "directus:pull": "node scripts/directus/pull-directus-cache.js",
    "dev:old": "concurrently -n \"SASS,SERVER\" -c \"yellow,blue\" \"npm run dev:css\" \"npm run dev:server\"",
    "dev:css": "sass src/styles/main.scss src/main.css --watch --source-map --load-path=src/styles",
    "dev:server": "cd src && live-server --port=3000 --open=/index.html --watch=.",
    "inject:partials": "node scripts/inject-partials.js",
    "build": "npm run lint:fix && vite build && npm run generate:build && node scripts/inject-partials.js",
    "build:vite": "npm run lint:fix && vite build",
    "build:astro:poc": "astro build",
    "check:astro:poc": "node scripts/astro/check-poc-parity.js",
    "check:astro:services": "node scripts/astro/check-service-output.js",
    "check:astro:blog": "node scripts/astro/check-blog-output.js",
    "check:astro:production": "node scripts/astro/check-production-output.js",
    "measure:astro:generation": "node scripts/astro/measure-generation.js",
    "build:astro:production": "bash scripts/astro/build-production.sh",
    "build:heavy": "npm run lint:fix && NODE_OPTIONS='--max-old-space-size=8192' vite build && npm run generate:build && node scripts/inject-partials.js",
    "build:hosting": "npm run lint:fix && BASE_PATH=./ NODE_ENV=production vite build && npm run generate:build && node scripts/inject-partials.js",
    "build:full": "bash scripts/build-full.sh",
    "build:github": "npm run lint:fix && BASE_PATH=/sk-rosa/ NODE_ENV=production vite build && npm run generate:build && node scripts/inject-partials.js",
    "generate": "node scripts/generator/generate-city-pages.js generate",
    "generate:build": "node scripts/generator/generate-city-pages.js build",
    "generate:clean": "node scripts/generator/generate-city-pages.js clean",
    "build:old": "npm run lint:fix && npm run build:clean && npm run build:css && npm run build:copy",
    "build:clean": "find public_html -mindepth 1 ! -name '.gitkeep' -delete 2>/dev/null || rm -rf public_html/* public_html/.* 2>/dev/null; mkdir -p public_html; touch public_html/.gitkeep",
    "build:css": "sass src/styles/main.scss public_html/main.css --style=compressed --no-source-map --load-path=src/styles",
    "build:copy": "cp -r src/* public_html/ && rm -rf public_html/styles/*.scss public_html/styles/blocks public_html/styles/helpers public_html/main.css.map public_html/node_modules public_html/package*.json public_html/package*.json.old public_html/.idea && find public_html -name '*.map' -delete 2>/dev/null || true",
    "deploy": "npm run build:github",
    "deploy:hosting": "npm run build:hosting",
    "deploy:sprint": "bash scripts/deploy.sh",
    "preview": "vite preview",
    "preview:astro": "astro preview --host 0.0.0.0 --port 4322",
    "preview:full": "concurrently -n \"PHP,VITE\" -c \"blue,green\" \"php -S localhost:8080 -t public_html/\" \"vite preview\"",
    "preview:old": "live-server --port=3000 --open=/public_html/index.html --watch=public_html",
    "serve": "cd public_html && php -S localhost:8000 router.php",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint src/scripts/**/*.js",
    "lint:css": "stylelint \"src/styles/**/*.scss\"",
    "lint:fix": "npm run lint:js:fix && npm run lint:css:fix",
    "lint:js:fix": "eslint src/scripts/**/*.js --fix",
    "lint:css:fix": "stylelint \"src/styles/**/*.scss\" --fix",
    "format": "prettier --write \"src/**/*.{js,html,json,scss}\"",
    "fix": "npm run lint && npm run lint:fix && npm run format",
    "format:check": "prettier --check \"src/**/*.{js,html,json,scss}\"",
    "analyze:css": "node analyze-css.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@astrojs/react": "^5.0.5",
    "@eslint/js": "^9.39.1",
    "@fullhuman/postcss-purgecss": "^7.0.2",
    "astro": "^6.3.3",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "live-server": "^1.2.2",
    "prettier": "^3.7.4",
    "rollup-plugin-visualizer": "^6.0.5",
    "sass": "^1.90.0",
    "stylelint": "^16.26.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "vite": "^7.3.0",
    "vite-plugin-static-copy": "^3.1.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
