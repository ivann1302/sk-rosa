{
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@scripts/*": ["./src/scripts/*"],
      "@core/*": ["./src/scripts/core/*"],
      "@modules/*": ["./src/scripts/modules/*"],
      "@features/*": ["./src/scripts/features/*"],
      "@utils/*": ["./src/scripts/utils/*"],
      "@api/*": ["./src/scripts/api/*"],
      "@styles/*": ["./src/styles/*"],
      "@assets/*": ["./src/assets/*"]
    },
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "bundler",
    "jsx": "preserve"
  },
  "include": [
    ".astro/types.d.ts",
    "astro/**/*",
    "src/**/*",
    "scripts/**/*",
    "tests/**/*",
    "*.config.js",
    "*.config.mjs"
  ],
  "exclude": ["node_modules", "public_html", "public_html_astro"]
}
