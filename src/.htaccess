# .htaccess для SK-ROSA (БЛОГ В КОРНЕ) ✅

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1. Старые URL статей блога и /articles/... ведём сразу на корневой canonical.
    RewriteCond %{DOCUMENT_ROOT}/$1.html -f
    RewriteRule ^blog/([A-Za-z0-9-]+)(?:\.html)?/?$ https://sk-rosa.ru/$1? [R=301,L]

    RewriteCond %{DOCUMENT_ROOT}/$1.html -f
    RewriteRule ^articles/([A-Za-z0-9-]+)(?:\.html)?/?$ https://sk-rosa.ru/$1? [R=301,L]

    # 2. Старые URL /pages/... → актуальные canonical.
    RewriteRule ^pages/(?:pages/)?index(?:\.html)?/?$ https://sk-rosa.ru/? [R=301,L]

    RewriteCond %{DOCUMENT_ROOT}/$1-$2.html -f
    RewriteRule ^pages/(turnkey-repair|plastering|airless-painting|floor-screed|biozashchita|soft-roofing)/([A-Za-z0-9-]+)(?:\.html)?/?$ https://sk-rosa.ru/$1-$2? [R=301,L]

    RewriteCond %{DOCUMENT_ROOT}/$1.html -f
    RewriteRule ^pages/(?:pages/|articles/)?([A-Za-z0-9-]+)(?:\.html)?/?$ https://sk-rosa.ru/$1? [R=301,L]

    # 3. Городские страницы услуг: /service/city → /service-city.
    RewriteCond %{DOCUMENT_ROOT}/$1-$2.html -f
    RewriteRule ^(turnkey-repair|plastering|airless-painting|floor-screed|biozashchita|soft-roofing)/([A-Za-z0-9-]+)(?:\.html)?/?$ https://sk-rosa.ru/$1-$2? [R=301,L]

    # 4. Убираем .html из URL страниц, но не трогаем проверочные и служебные файлы.
    RewriteRule ^index\.html$ https://sk-rosa.ru/? [R=301,L]

    RewriteCond %{REQUEST_URI} !^/(404|yandex_[^/]+)\.html$ [NC]
    RewriteCond %{REQUEST_URI} !^/(assets|scripts)/ [NC]
    RewriteCond %{THE_REQUEST} \s/+(.+)\.html[\s?] [NC]
    RewriteCond %{DOCUMENT_ROOT}/$1.html -f
    RewriteRule ^(.+)\.html$ https://sk-rosa.ru/$1? [R=301,L]

    # 5. Слеш → без слеша, если существует одноименная HTML-страница.
    RewriteCond %{REQUEST_URI} ^(.+)/$
    RewriteCond %{REQUEST_URI} !^/(assets|scripts)/ [NC]
    RewriteCond %{DOCUMENT_ROOT}%1.html -f
    RewriteRule ^(.+)/$ https://sk-rosa.ru/$1? [R=301,L]

    # 6. Убираем параметрические дубли из рекламных систем.
    RewriteCond %{QUERY_STRING} (^|&)yclid=[^&]*(&|$) [NC]
    RewriteRule ^ https://sk-rosa.ru%{REQUEST_URI}? [R=301,L]

    # 7. Канонический хост и протокол: все варианты ведём на https://sk-rosa.ru.
    RewriteCond %{HTTP_HOST} !^sk-rosa\.ru$ [NC]
    RewriteRule ^(.*)$ https://sk-rosa.ru/$1 [R=301,L]

    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
    RewriteRule ^(.*)$ https://sk-rosa.ru/$1 [R=301,L]

    # /blog → /blog.html
    RewriteRule ^blog/?$ /blog.html [L]

    # 8. Если файл/папка НЕ существует → ищем .html
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^(.*)$ $1.html [L]

    # 9. Всё остальное → 404
    RewriteCond %{REQUEST_URI} !^/(assets|scripts)/ [NC]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.html !-f
    RewriteRule ^(.*)$ /404.php [L]
</IfModule>

# Безопасность
Options -Indexes
ErrorDocument 404 /404.php

# Защита файлов
<Files ".env">
    Order allow,deny
    Deny from all
</Files>

<Files "router.php">
    Order allow,deny
    Deny from all
</Files>

<FilesMatch "^(test-.*\.php)$">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "^(check_forms|load-env)\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

# 🔥 SECURITY HEADERS (оставляем как есть)
<IfModule mod_headers.c>
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    # Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' mc.yandex.ru *.yandex.ru api-maps.yandex.ru; style-src 'self' 'unsafe-inline' cdn.jsdelivr.net fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: fonts.gstatic.com cdn.jsdelivr.net; connect-src 'self' https: mc.yandex.ru *.yandex.ru;"
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# Сжатие Gzip
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json application/xml text/xml text/plain image/svg+xml font/woff font/woff2
    BrowserMatch ^Mozilla/4 gzip-only-text/html
    BrowserMatch ^Mozilla/4\.0[678] no-gzip
    BrowserMatch \\bMSIE !no-gzip !gzip-only-text/html
</IfModule>

# Кеширование
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>
