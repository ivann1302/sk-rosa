---
import BlogCard from "./BlogCard.astro";

const { articles, categories } = Astro.props;
---

<section class="blog-hero">
  <div class="blog-hero__container">
    <div class="blog-hero__wrapper">
      <div class="blog-hero__content">
        <h1 class="blog-hero__title">
          <span class="blog-hero__title-static">Блог</span>
          <span class="blog-hero__title-animated">
            <span class="blog-hero__title-list">
              <span class="blog-hero__title-item">о ремонте и отделке</span>
              <span class="blog-hero__title-item">о материалах и технологиях</span>
              <span class="blog-hero__title-item">с советами и рекомендациями</span>
            </span>
          </span>
        </h1>
        <p class="blog-hero__description">
          Полезные статьи о ремонте, отделке и выборе материалов. Советы от профессионалов с
          многолетним опытом работы в Москве и Московской области.
        </p>
        <div class="blog-hero__search">
          <form class="blog-search" action="#" method="get" role="search">
            <div class="blog-search__wrapper">
              <input
                type="search"
                class="blog-search__input"
                placeholder="Поиск статей..."
                aria-label="Поиск статей"
                name="q"
              />
              <div class="blog-search__controls">
                <button type="button" class="blog-search__clear" aria-label="Очистить поиск">
                  <svg
                    width="18"
                    height="18"
                    viewBox="0 0 18 18"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path
                      d="M13.5 4.5l-9 9M4.5 4.5l9 9"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"></path>
                  </svg>
                </button>
                <button type="submit" class="blog-search__button" aria-label="Найти">
                  <svg
                    width="20"
                    height="20"
                    viewBox="0 0 20 20"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path
                      d="M9 17A8 8 0 1 0 9 1a8 8 0 0 0 0 16z"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"></path>
                    <path
                      d="m19 19-4.35-4.35"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"></path>
                  </svg>
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>
      <div class="blog-hero__image">
        <img
          src="/assets/icons/common/Construction worker-bro.svg"
          alt="Строитель"
          class="blog-hero__image-img"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>

<section class="blog-articles">
  <div class="blog-articles__container">
    <div class="blog-filter">
      {
        categories.map(category => (
          <button
            class:list={[
              "blog-filter__button",
              { "blog-filter__button--active": category.slug === "all" },
            ]}
            data-category={category.slug}
          >
            {category.label}
          </button>
        ))
      }
    </div>

    <div class="blog-grid">
      {articles.map(article => <BlogCard article={article} />)}
    </div>
  </div>
</section>
