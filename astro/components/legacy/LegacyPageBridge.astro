---
import BaseLayout from "../BaseLayout.astro";
import LegacyRuntime from "../LegacyRuntime.astro";
import {
  extractBetween,
  extractLegacyJsonLd,
  extractLegacySeo,
  normalizeLegacyPaths,
} from "../../lib/legacy-html.js";
import { businessId } from "../../lib/seo.js";

interface Props {
  sourceHtml: string;
}

const { sourceHtml } = Astro.props;
const seo = extractLegacySeo(sourceHtml);
const jsonLd = extractLegacyJsonLd(sourceHtml).map(normalizeLegacyJsonLd);
const contentHtml = normalizeLegacyPaths(
  extractBetween(sourceHtml, "<!-- HEADER -->", "<!-- FOOTER -->"),
);

function normalizeLinkedEntity(value) {
  if (!value || typeof value !== "object") {
    return value;
  }

  const types = Array.isArray(value["@type"]) ? value["@type"] : [value["@type"]];

  if (types.some(type => ["Organization", "LocalBusiness", "HomeAndConstructionBusiness"].includes(type))) {
    return {
      "@id": businessId,
    };
  }

  return value;
}

function normalizeLegacyJsonLd(item) {
  if (Array.isArray(item)) {
    return item.map(normalizeLegacyJsonLd);
  }

  if (!item || typeof item !== "object") {
    return item;
  }

  const normalized = { ...item };

  if (normalized.provider) {
    normalized.provider = normalizeLinkedEntity(normalized.provider);
  }

  if (normalized.publisher) {
    normalized.publisher = normalizeLinkedEntity(normalized.publisher);
  }

  return normalized;
}
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  ogType={seo.ogType}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
  ogImage={seo.ogImage}
  ogImageSecureUrl={seo.ogImageSecureUrl}
  ogImageWidth={seo.ogImageWidth}
  ogImageHeight={seo.ogImageHeight}
  ogImageType={seo.ogImageType}
  ogImageAlt={seo.ogImageAlt}
  ogSiteName={seo.ogSiteName}
  jsonLd={jsonLd}
>
  <Fragment set:html={contentHtml} />
  <LegacyRuntime slot="runtime" sourceHtml={sourceHtml} />
</BaseLayout>
