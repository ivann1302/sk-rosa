---
const socialLinks = [
  {
    href: "https://t.me/sk_rosa",
    label: "Telegram",
    icon: "/assets/images/common/telegram_icon.png",
  },
  {
    href: "https://wa.me/79851354991",
    label: "WhatsApp",
    icon: "/assets/images/common/whatsapp_icon.png",
  },
  {
    href: "https://dzen.ru/id/699317fa4c68660edaa347ae?share_to=link",
    label: "Яндекс Дзен",
    icon: "/assets/images/icons/flaticon/dzen.svg",
  },
  {
    href: "https://vk.com/skrosa",
    label: "ВКонтакте",
    icon: "/assets/images/icons/flaticon/vk.svg",
  },
  {
    href: "https://ok.ru/group/70000044485400",
    label: "Одноклассники",
    icon: "/assets/images/icons/flaticon/ok.svg",
  },
];
---

<aside class="social-fixed" aria-label="Социальные сети" data-js-social-fixed>
  <button
    class="social-fixed__toggle"
    type="button"
    aria-label="Показать соцсети"
    data-js-social-toggle
  >
    <svg width="12" height="20" viewBox="0 0 12 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M10 2L2 10L10 18"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  </button>
  <div class="social-fixed__links">
    {
      socialLinks.map(link => (
        <a
          class="social-fixed__link"
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={link.label}
        >
          <img
            src={link.icon}
            alt={link.label}
            width="32"
            height="32"
            loading="lazy"
            decoding="async"
          />
        </a>
      ))
    }
  </div>
</aside>
