---
import CallBanner from "../common/CallBanner.astro";
import FloatingSocials from "../common/FloatingSocials.astro";
import SuccessModal from "../common/SuccessModal.astro";

const { callBannerComments, callBannerSource } = Astro.props;
---

<FloatingSocials />
<SuccessModal />
<script src="/scripts/core/constants.js" defer></script>
<script src="/scripts/features/contact/init-contacts.js" defer></script>
<script type="module" src="/scripts/features/contact/lazy-yandex-maps.js" defer></script>
<script src="/scripts/core/carousel.js" defer></script>
<script src="/scripts/features/portfolio/portfolio-turnkey.js" defer></script>
<script src="/scripts/features/contact/success-modal.js" defer></script>
<script type="module" src="/scripts/features/contact/form-handler.js" defer></script>
<script type="module" src="/scripts/features/portfolio/custom-select.js" defer></script>
<script type="module" src="/scripts/core/main.js" defer></script>
<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    const grid = document.querySelector(".reviews__grid");
    const leftBtn = document.querySelector(".review-grid-arrow--left");
    const rightBtn = document.querySelector(".review-grid-arrow--right");

    if (!grid || !leftBtn || !rightBtn) {
      return;
    }

    function updateArrows() {
      const atStart = grid.scrollLeft <= 0;
      const atEnd = grid.scrollLeft >= grid.scrollWidth - grid.offsetWidth - 1;

      leftBtn.classList.toggle("review-grid-arrow--disabled", atStart);
      rightBtn.classList.toggle("review-grid-arrow--disabled", atEnd);
    }

    function getCardWidth() {
      const card = grid.querySelector(".review-card");

      return card ? card.offsetWidth + 12 : 0;
    }

    leftBtn.addEventListener("click", function () {
      grid.scrollBy({ left: -getCardWidth(), behavior: "smooth" });
    });

    rightBtn.addEventListener("click", function () {
      grid.scrollBy({ left: getCardWidth(), behavior: "smooth" });
    });

    grid.addEventListener("scroll", updateArrows);
    updateArrows();
  });
</script>
<CallBanner comments={callBannerComments} formSource={callBannerSource} />
<script src="/scripts/features/contact/call-banner.js" defer></script>
