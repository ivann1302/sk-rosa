---
import ArticlesCarousel from "./ArticlesCarousel.astro";
import CityComplexes from "./CityComplexes.astro";
import CityLocalContent from "./CityLocalContent.astro";
import FaqSection from "./FaqSection.astro";
import ReviewsSection from "./ReviewsSection.astro";
import ServiceQuiz from "./ServiceQuiz.jsx";
import { getServiceQuiz } from "../../data/service-quizzes.js";

const { page } = Astro.props;
const city = page.city;
const serviceQuiz = getServiceQuiz(page.service.slug);
const heroLocation = city?.nameIn ? `в ${city.nameIn}` : "в Москве";
const calcComments = city?.name
  ? `Заявка на расчет ремонта в ${city.nameIn}`
  : "Заявка на расчет с формы калькулятора";
const calcSource = city?.name
  ? `Ремонт под ключ - Калькулятор (${city.name})`
  : "Ремонт под ключ - Калькулятор";
const textTitle = page.textBlock.title;
const choiceReasons = [
  "<strong>Официальный договор</strong> с фиксированными ценами",
  "<strong>Собственная бригада</strong> проверенных мастеров",
  "<strong>Поэтапная оплата</strong> по факту выполненных работ",
  "<strong>Гарантия 3 года</strong> на все виды работ",
  "<strong>Чёткие сроки</strong> без затягивания ремонта",
];
const stageIcons = [
  {
    name: "salesman",
    icon: "/assets/icons/features/turnkey/salesman-svgrepo-com.svg",
    alt: "Консультация",
  },
  {
    name: "record",
    icon: "/assets/icons/features/turnkey/data-report-svgrepo-com.svg",
    alt: "Составление сметы",
  },
  {
    name: "record-second",
    icon: "/assets/icons/features/turnkey/record-svgrepo-com.svg",
    alt: "Подписание договора",
  },
  {
    name: "idea",
    icon: "/assets/icons/features/turnkey/idea-svgrepo-com.svg",
    alt: "Делаем ремонт",
  },
  {
    name: "like",
    icon: "/assets/icons/features/turnkey/like-svgrepo-com.svg",
    alt: "Сдача проекта",
  },
];
const usefulLinks = [
  {
    href: "/calculator",
    title: "Калькулятор ремонта",
    image: "/assets/images/common/calculator.jpg",
    alt: "Калькулятор",
  },
  {
    href: "/blog",
    title: "Блог о ремонте",
    image: "/assets/images/common/blog.jpg",
    alt: "Блог",
  },
  {
    href: "#contact-request-turnkey",
    title: "Консультация",
    image: "/assets/images/common/consultation.jpg",
    alt: "Консультация",
  },
  {
    title: "Сертификаты и лицензии",
    image: "/assets/images/common/certificates.jpg",
    alt: "Сертификаты",
  },
  {
    title: "Работа по договору",
    image: "/assets/images/common/contract.jpg",
    alt: "Работа по договору",
  },
];
---

<section class="about-turnkey">
  <div class="about-turnkey__container">
    <picture>
      <source srcset={page.hero.image.webp} type="image/webp" />
      <img
        class="about-turnkey__image"
        src={page.hero.image.fallback}
        alt={page.hero.image.alt}
        fetchpriority="high"
        loading="eager"
        width="720"
        height="480"
      />
    </picture>
    <div class="about-turnkey__content">
      <p class="about-turnkey__subtitle-small">Что мы предлагаем</p>
      <h1 class="about-turnkey__title">
        Ремонт квартир, домов, офисов,<br />
        коммерческих помещений под ключ {heroLocation}
      </h1>
      <div class="about-turnkey__row">
        <a
          href="/portfolio"
          class="about-turnkey__btn about-turnkey__btn--secondary"
        >
          Портфолио
        </a>
        <a href="#contact-request-turnkey" class="about-turnkey__btn">
          Заказать консультацию
        </a>
      </div>
    </div>
  </div>

  {
    serviceQuiz && (
      <ServiceQuiz
        client:load
        formSource={page.priceCalc.quizFormSource}
        questions={serviceQuiz.questions}
        serviceName={serviceQuiz.serviceName}
        title={page.priceCalc.quizTitle}
      />
    )
  }

  <section class="about-turnkey-2" id="prices">
    <div class="about-turnkey-2__container">
      <div class="about-turnkey-2__left">
        <h2 class="about-turnkey-2__title">КОМПЛЕКСНЫЙ РЕМОНТ КВАРТИРЫ</h2>
        <div class="about-turnkey-2__subtitle">Сделаем ремонт в обозначенный срок</div>
        <div class="about-turnkey-2__price">от 10 000 ₽ м²</div>
      </div>
      <div class="about-turnkey-2__right">
        <h3 class="about-turnkey-2__calc-title">КАЛЬКУЛЯТОР РЕМОНТА</h3>
        <form class="about-turnkey-2__form" action="/scripts/api/send.php" method="POST">
          <div
            aria-hidden="true"
            style="position:absolute;left:-10000px;top:auto;width:1px;height:1px;overflow:hidden;opacity:0;pointer-events:none;"
          >
            <label>
              Сайт компании
              <input type="text" name="company_website" tabindex="-1" autocomplete="off" />
            </label>
          </div>
          <div class="about-turnkey-2__field">
            <label class="about-turnkey-2__label">Объект</label>
            <div class="custom-select about-turnkey-2__select-wrapper">
              <input type="hidden" name="property_type" value="apartment" />
              <button
                type="button"
                class="custom-select__button"
                aria-haspopup="listbox"
                aria-expanded="false"
              >
                <span class="custom-select__text">Квартира</span>
                <svg
                  class="custom-select__icon"
                  width="16"
                  height="16"
                  viewBox="0 0 20 20"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d="m6 8 4 4 4-4"></path>
                </svg>
              </button>
              <ul class="custom-select__dropdown" role="listbox" aria-hidden="true">
                <li
                  class="custom-select__option custom-select__option--selected"
                  role="option"
                  data-value="apartment"
                  tabindex="0"
                  aria-selected="true"
                >
                  Квартира
                </li>
                <li class="custom-select__option" role="option" data-value="office" tabindex="0">
                  Дом
                </li>
                <li class="custom-select__option" role="option" data-value="house" tabindex="0">
                  Офис
                </li>
              </ul>
            </div>
          </div>
          <div class="about-turnkey-2__field">
            <label class="about-turnkey-2__label">Площадь, м²</label>
            <input
              class="about-turnkey-2__input"
              type="number"
              name="AREA"
              min="1"
              max="10000"
              inputmode="numeric"
              placeholder="50"
              required
            />
          </div>
          <div class="about-turnkey-2__field">
            <label class="about-turnkey-2__label">Имя</label>
            <input
              class="about-turnkey-2__input"
              type="text"
              name="NAME"
              autocomplete="name"
              placeholder="Ваше имя"
              required
            />
          </div>
          <div class="about-turnkey-2__field">
            <label class="about-turnkey-2__label">Телефон</label>
            <input
              class="about-turnkey-2__input"
              type="tel"
              name="PHONE"
              autocomplete="tel"
              placeholder="+7 (999) 123-45-67"
              required
            />
          </div>
          <input type="hidden" name="COMMENTS" value={calcComments} />
          <input type="hidden" name="form_source" value={calcSource} />
          <button class="about-turnkey-2__btn" type="submit">Рассчитать</button>
        </form>
      </div>
    </div>
  </section>

  <section class="advantages-turnkey reveal-on-scroll">
    <div class="advantages-turnkey__container">
      <div class="advantages-turnkey__list">
        {
          page.advantages.map(item => (
            <div class="advantages-turnkey__item">
              <div class="advantages-turnkey__icon">
                <img src={item.icon} alt={item.alt} width="48" height="48" />
              </div>
              <div class="advantages-turnkey__content">
                <h3 class="advantages-turnkey__title">{item.value}</h3>
                <div class="advantages-turnkey__desc">{item.description}</div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {
    page.complexes && page.complexes.length > 0 && (
      <CityComplexes cityNameIn={city.nameIn} complexes={page.complexes} />
    )
  }

  <section class="service-text-block reveal-on-scroll">
    <div class="service-text-block__container">
      <h2 class="service-text-block__title">{textTitle}</h2>
      <p class="service-text-block__subtitle">
        <strong>Полный цикл ремонтных работ</strong> – от демонтажа до чистовой отделки
      </p>

      <div class="service-text-block__content">
        <p>
          Нужен <strong>качественный ремонт квартиры или дома {heroLocation}</strong> без головной
          боли? Выполним весь комплекс работ – от проектирования и демонтажа до финишной отделки и
          уборки.
        </p>
        <p>
          Работаем с <strong>новостройками и вторичным жильём</strong>. Используем проверенные
          материалы и соблюдаем все строительные нормы.
        </p>
      </div>

      <h3 class="service-text-block__list-title">Почему выбирают нас</h3>
      <ul class="service-text-block__check-list">
        {
          choiceReasons.map(reason => (
            <li>
              <svg
                class="service-text-block__check-icon"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
              <span set:html={reason} />
            </li>
          ))
        }
      </ul>

      <h3 class="service-text-block__list-title">Что входит в ремонт под ключ</h3>
      <ul class="service-text-block__object-list">
        {
          page.taskList.map(item => (
            <li>
              <svg
                class="service-text-block__arrow-icon"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M9 5l7 7-7 7"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
              <span>{item.name}</span>
            </li>
          ))
        }
      </ul>

      <p class="service-text-block__note">
        Стоимость зависит от площади и объёма работ.
        <strong>Бесплатный выезд и расчёт сметы.</strong>
      </p>

      <p class="service-text-block__note">
        <strong>{textTitle}</strong> – без переделок и скрытых доплат. Оставьте заявку – рассчитаем
        стоимость и согласуем удобную дату начала работ.
      </p>
    </div>
  </section>

  <CityLocalContent content={page.localContent} />

  <section class="company-description-turnkey reveal-on-scroll">
    <div class="company-description-turnkey__container">
      <h2 class="visually-hidden">О компании</h2>
      <div class="company-description-turnkey__content">
        <div class="company-description-turnkey__text">
          <p class="portfolio-description__text">
            Компания "Роса" более 6 лет занимается комплексным ремонтом квартир и домов под ключ,
            реализуя проекты различной сложности с индивидуальным подходом к каждому клиенту. В
            команде работают опытные специалисты, преданные своему делу и постоянно развивающие
            профессиональные навыки. Мы ценим доверие и работаем только по официальному договору,
            обеспечивая прозрачность и честность на всех этапах — от консультации и сметы до
            финальной сдачи объекта. Используем качественные материалы и современные технологии,
            чтобы результат радовал долгие годы и превосходил ожидания заказчика.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="work-stages-turnkey reveal-on-scroll">
    <div class="work-stages-turnkey__container">
      <div class="work-stages-turnkey__row">
        <h2 class="work-stages-turnkey__title">Как мы работаем?</h2>
        <div class="work-stages-turnkey__line">
          <div class="work-stages-turnkey__line-inner"></div>
          <div class="work-stages-turnkey__quarter-circle"></div>
          <div class="work-stages-turnkey__vertical-line"></div>
          <div class="work-stages-turnkey__quarter-circle-left"></div>
          <div class="work-stages-turnkey__horizontal-line-2"></div>
          <div class="work-stages-turnkey__horizontal-line-to-step5"></div>
          {
            stageIcons.map(item => (
              <div class={`work-stages-turnkey__icon work-stages-turnkey__icon--${item.name}`}>
                <img src={item.icon} alt={item.alt} width="60" height="60" />
              </div>
            ))
          }
          {
            page.stages.items.map((step, index) => {
              return (
                <div
                  class={`work-stages-turnkey__text work-stages-turnkey__text--${stageIcons[index].name}`}
                >
                  <h3 class="work-stages-turnkey__text-title">{step.title}</h3>
                  <p class="work-stages-turnkey__text-desc">{step.description}</p>
                </div>
              );
            })
          }
        </div>
      </div>
    </div>
  </section>

  <ReviewsSection reviews={page.reviews} />

  <section class="useful-links reveal-on-scroll" style="background: #fff; padding: 40px 0">
    <div class="useful-links__container" style="max-width: 1200px; margin: 0 auto; padding: 0">
      <h2 class="useful-links__title">Собрали для вас все самые полезные ссылки</h2>
      <div class="useful-links__grid">
        {
          usefulLinks.map(item => (
            item.href ? (
              <a href={item.href} class="useful-links__item">
                <h3 class="useful-links__item-title">{item.title}</h3>
                <img src={item.image} alt={item.alt} />
              </a>
            ) : (
              <div class="useful-links__item">
                <h3 class="useful-links__item-title">{item.title}</h3>
                <img src={item.image} alt={item.alt} />
              </div>
            )
          ))
        }
      </div>
    </div>
  </section>

  <section id="contact-request-turnkey" class="contact-request-turnkey reveal-on-scroll">
    <div class="contact-request-turnkey__container">
      <div class="contact-request-turnkey__content">
        <div class="contact-request-turnkey__form">
          <form
            class="contact-request-turnkey__form-fields"
            action="/scripts/api/send.php"
            method="POST"
          >
            <div
              aria-hidden="true"
              style="position:absolute;left:-10000px;top:auto;width:1px;height:1px;overflow:hidden;opacity:0;pointer-events:none;"
            >
              <label>
                Сайт компании
                <input type="text" name="company_website" tabindex="-1" autocomplete="off" />
              </label>
            </div>
            <div class="contact-request-turnkey__field">
              <label for="turnkey-contact-name">Ваше имя *</label>
              <input
                type="text"
                id="turnkey-contact-name"
                name="NAME"
                autocomplete="name"
                placeholder="Введите ваше имя"
                required
              />
            </div>
            <div class="contact-request-turnkey__field">
              <label for="turnkey-contact-phone">Телефон *</label>
              <input
                type="tel"
                id="turnkey-contact-phone"
                name="PHONE"
                autocomplete="tel"
                placeholder="+7 (___) ___-__-__"
                required
              />
            </div>
            <input type="hidden" name="COMMENTS" value={page.contact.comments} />
            <input type="hidden" name="property_type" value="apartment" />
            <input type="hidden" name="form_source" value={page.contact.formSource} />
            <button type="submit" class="contact-request-turnkey__submit">
              Отправить заявку
            </button>
          </form>
        </div>
        <div class="contact-request-turnkey__info">
          <h2 class="contact-request-turnkey__title">{page.contact.title}</h2>
          <p class="contact-request-turnkey__subtitle">{page.contact.subtitle}</p>

          <div class="contact-request-turnkey__features">
            {
              page.contact.features.map(feature => (
                <div class="contact-request-turnkey__feature">
                  <div class="contact-request-turnkey__feature-icon">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path
                        d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </div>
                  <div class="contact-request-turnkey__feature-text">{feature}</div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <FaqSection
    title="Ответы на частые вопросы"
    description={page.faqDescription}
    items={page.faq}
  />
</section>

<section class="portfolio-description reveal-on-scroll">
  <div class="portfolio-description__container">
    <h2 class="portfolio-description__title">Наши работы — ваш ориентир</h2>
    <p class="portfolio-description__text">
      В портфолио ROSA — реальные интерьеры, которые мы реализовали для клиентов с разными
      задачами, вкусами и метражом. Это не визуализации, а готовые квартиры, где уже живут люди.
      Посмотрите, каким может быть ваш будущий интерьер — от планировки до финальной отделки.
    </p>
    <p class="portfolio-description__text">
      Понравился стиль или подход? Узнайте, сколько может стоить ремонт в вашей квартире —
      воспользуйтесь удобным калькулятором, чтобы прикинуть бюджет и понять, с чего начать.
      <a href="/calculator" class="portfolio-description__button">
        Рассчитать стоимость
        <img
          src="/assets/icons/common/share-alt-svgrepo-com.svg"
          alt="Поделиться"
          width="16"
          height="16"
        />
      </a>
    </p>
  </div>
</section>

<section class="portfolio-turnkey" id="portfolio">
  <div class="portfolio-turnkey__container">
    <div class="portfolio-turnkey__project">
      <div class="portfolio-turnkey__project-image">
        <picture>
          <source
            srcset="/assets/images/turnkey/u2928876119_A_modern_apartment_interior_under_renovation_in_Mos_558d60a4-8854-4bc1-ba21-41732a3926ad.webp"
            type="image/webp"
          />
          <img
            src="/assets/images/portfolio/10.png"
            alt="Интерьер квартиры"
            id="project-image"
          />
        </picture>
      </div>
      <div
        class="portfolio-turnkey__content-card"
        style="background: #fff; border-radius: 8px; padding: 24px; box-shadow: 0 2px 16px rgba(0, 0, 0, 0.07)"
      >
        <div class="portfolio-turnkey__project-header" id="project-location">
          г. Москва, ЖК "Московский"
        </div>
        <h2 class="portfolio-turnkey__project-title" id="project-title">
          Дизайн-проект однокомнатной квартиры
        </h2>
        <div class="portfolio-turnkey__project-costs-row">
          <div class="portfolio-turnkey__project-cost">
            <span class="portfolio-turnkey__cost-label">Площадь объекта</span>
            <span class="portfolio-turnkey__cost-amount" id="project-area">32.12м²</span>
          </div>
          <div class="portfolio-turnkey__project-cost">
            <span class="portfolio-turnkey__cost-label">Стоимость ремонта</span>
            <span class="portfolio-turnkey__cost-amount" id="project-price">885 443 ₽</span>
          </div>
        </div>
        <p class="portfolio-turnkey__project-description" id="project-description">
          Модернизм выделяется утончённым дизайном и оригинальной архитектурой. Гармония базовых
          тонов с яркими акцентами подчёркивает стиль, а удобная мебель делает пространство
          комфортным для жизни.
        </p>
        <div class="portfolio-turnkey__navigation">
          <div class="portfolio-turnkey__nav-buttons">
            <button
              class="portfolio-turnkey__nav-btn portfolio-turnkey__nav-btn--prev"
              id="prev-btn"
            >
              <img
                src="/assets/icons/features/turnkey/right-arrow-svgrepo-com.svg"
                alt="Предыдущий"
                width="30"
                height="30"
              />
            </button>
            <button
              class="portfolio-turnkey__nav-btn portfolio-turnkey__nav-btn--next"
              id="next-btn"
            >
              <img
                src="/assets/icons/features/turnkey/right-arrow-svgrepo-com.svg"
                alt="Следующий"
                width="30"
                height="30"
              />
            </button>
          </div>
          <div class="portfolio-turnkey__nav-counter-card">
            <span class="portfolio-turnkey__nav-counter" id="project-counter">1 / 10</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<ArticlesCarousel
  title="Полезные статьи о ремонте"
  articles={page.articles}
  moreHref="/blog"
  moreLabel="Посмотреть другие статьи"
/>

<style is:global>
  @media (max-width: 768px) {
    .about-turnkey__content,
    .about-turnkey-2__container,
    .about-turnkey-2__left,
    .about-turnkey-2__right {
      box-sizing: border-box;
      max-width: 100%;
      overflow: hidden;
    }

    .about-turnkey__title,
    .about-turnkey-2__title {
      overflow-wrap: anywhere;
      word-break: normal;
      line-height: 1.2;
    }

    .about-turnkey__title {
      font-size: clamp(1.45rem, 6.4vw, 1.75rem);
    }

    .about-turnkey-2__title {
      font-size: clamp(1.2rem, 5.4vw, 1.55rem);
    }

    .about-turnkey__title,
    .about-turnkey-2__title,
    .about-turnkey-2__calc-title,
