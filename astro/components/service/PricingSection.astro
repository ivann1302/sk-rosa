---
const { title, containerId = "pricing-table-container", items = [], note } = Astro.props;
const hasItems = items.length > 0;
---

<section class="pricing-section reveal-on-scroll" id="pricing-table">
  <div class="pricing-section__container">
    <h2 class="pricing-section__title">{title}</h2>
    <div id={containerId}>
      {
        hasItems && (
          <div class="pricing-table-wrapper">
            <table class="pricing-table">
              <thead>
                <tr>
                  <th>Услуга</th>
                  <th>Цена</th>
                  <th>Ед. изм.</th>
                </tr>
              </thead>
              <tbody>
                {items.map(item => {
                  const isFree = item.price.toLowerCase().includes("бесплатно");
                  const hasNumericPrice = /\d/.test(item.price);

                  return (
                    <tr
                      class={`pricing-table__row${isFree ? " pricing-table__row--free" : ""}`}
                    >
                      <td>
                        <span class="pricing-table__service-name">{item.service}</span>
                      </td>
                      <td>
                        {isFree ? (
                          <span class="pricing-table__free">{item.price}</span>
                        ) : hasNumericPrice ? (
                          `${item.price} руб`
                        ) : (
                          item.price
                        )}
                      </td>
                      <td>{item.unit}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        )
      }
    </div>
    {
      note && (
        <p class="pricing-section__note">
          {note.text} <a href={note.href}>{note.label}</a>
        </p>
      )
    }
  </div>
</section>
