---
const { content, slider = false } = Astro.props;
---

{
  content && (
    <section
      class:list={[
        "city-local-content reveal-on-scroll",
        { "city-local-content--slider": slider },
      ]}
    >
      <div class="city-local-content__container">
        <div class="city-local-content__header">
          {
            slider ? (
              <div class="city-local-content__title-row">
                <span class="city-local-content__title-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24">
                    <path d="M20 10c0 5-8 11-8 11S4 15 4 10a8 8 0 1 1 16 0Z" />
                    <circle cx="12" cy="10" r="2.5" />
                  </svg>
                </span>
                <h2 class="city-local-content__title">{content.title}</h2>
              </div>
            ) : (
              <h2 class="city-local-content__title">{content.title}</h2>
            )
          }
          {content.subtitle && <p class="city-local-content__subtitle">{content.subtitle}</p>}
        </div>

        <div class="city-local-content__lead">
          {content.lead.map(paragraph => <p class="city-local-content__lead-text">{paragraph}</p>)}
        </div>

        {
          slider && (
            <div class="city-local-content__controls" aria-label="Навигация по карточкам">
              <button
                class="city-local-content__control city-local-content__control--prev"
                type="button"
                aria-label="Предыдущая карточка"
                data-city-slider-prev
              >
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="m15 5-7 7 7 7" />
                </svg>
              </button>
              <button
                class="city-local-content__control city-local-content__control--next"
                type="button"
                aria-label="Следующая карточка"
                data-city-slider-next
              >
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="m9 5 7 7-7 7" />
                </svg>
              </button>
            </div>
          )
        }

        <div class="city-local-content__grid" data-city-slider-track={slider || undefined}>
          {content.blocks.map(block => (
            <article class="city-local-content__block">
              <h3 class="city-local-content__block-title">{block.title}</h3>
              {
                block.paragraphs?.map(paragraph => (
                  <p class="city-local-content__block-text">{paragraph}</p>
                ))
              }
              {block.items && (
                <ul class="city-local-content__list">
                  {block.items.map(item => <li>{item}</li>)}
                </ul>
              )}
              {block.note && <p class="city-local-content__note">{block.note}</p>}
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}

<script>
  document.querySelectorAll(".city-local-content--slider").forEach(section => {
    const track = section.querySelector("[data-city-slider-track]");
    const previous = section.querySelector("[data-city-slider-prev]");
    const next = section.querySelector("[data-city-slider-next]");

    if (
      !(track instanceof HTMLElement) ||
      !(previous instanceof HTMLButtonElement) ||
      !(next instanceof HTMLButtonElement)
    ) {
      return;
    }

    const getStep = () => {
      const card = track.querySelector(".city-local-content__block");
      const gap = Number.parseFloat(getComputedStyle(track).columnGap) || 0;

      return card instanceof HTMLElement ? card.offsetWidth + gap : track.clientWidth;
    };

    const updateControls = () => {
      const maximum = track.scrollWidth - track.clientWidth;

      previous.disabled = track.scrollLeft <= 2;
      next.disabled = track.scrollLeft >= maximum - 2;
    };

    previous.addEventListener("click", () => {
      track.scrollBy({ left: -getStep(), behavior: "smooth" });
    });

    next.addEventListener("click", () => {
      track.scrollBy({ left: getStep(), behavior: "smooth" });
    });

    track.addEventListener("scroll", updateControls, { passive: true });
    window.addEventListener("resize", updateControls);
    updateControls();
  });
</script>
