---
import BaseLayout from "../components/BaseLayout.astro";
import BlogArticleBridge from "../components/blog/BlogArticleBridge.astro";
import ArticlesCarousel from "../components/service/ArticlesCarousel.astro";
import CityComplexes from "../components/service/CityComplexes.astro";
import CityLocalContent from "../components/service/CityLocalContent.astro";
import ContactRequest from "../components/service/ContactRequest.astro";
import FaqSection from "../components/service/FaqSection.astro";
import InternalLinksSection from "../components/service/InternalLinksSection.astro";
import PlasteringCasesSection from "../components/service/PlasteringCasesSection.astro";
import PlasteringHeroBenefits from "../components/service/PlasteringHeroBenefits.astro";
import PlasteringRatings from "../components/service/PlasteringRatings.astro";
import PriceCalcSection from "../components/service/PriceCalcSection.astro";
import PricingSection from "../components/service/PricingSection.astro";
import ReviewsSection from "../components/service/ReviewsSection.astro";
import ServiceAdvantages from "../components/service/ServiceAdvantages.astro";
import ServiceHero from "../components/service/ServiceHero.astro";
import ServiceQuiz from "../components/service/ServiceQuiz.jsx";
import ServiceRuntime from "../components/service/ServiceRuntime.astro";
import ServiceSteps from "../components/service/ServiceSteps.astro";
import ServiceTaskList from "../components/service/ServiceTaskList.astro";
import ServiceTextBlock from "../components/service/ServiceTextBlock.astro";
import TurnkeyRepairLegacyPage from "../components/service/TurnkeyRepairLegacyPage.astro";
import TurnkeyRepairLegacyRuntime from "../components/service/TurnkeyRepairLegacyRuntime.astro";
import { blogArticlePages } from "../data/blog.js";
import { plasteringPage } from "../data/plastering.js";
import { getServiceQuiz } from "../data/service-quizzes.js";
import { serviceCityPages } from "../data/service-city-pages.js";
import { getCityInterlinkGroups } from "../data/site-links.js";
import { breadcrumbJsonLd } from "../lib/seo.js";

export function getStaticPaths() {
  return [
    ...serviceCityPages.map(({ route, page }) => ({
      params: { cityPage: route },
      props: { kind: "service-city", page },
    })),
    ...blogArticlePages.map(article => ({
      params: { cityPage: article.slug },
      props: { kind: "blog-article", article },
    })),
  ];
}

const { article, kind, page } = Astro.props;
const isBlogArticle = kind === "blog-article";
const city = isBlogArticle ? null : page.city;
const seo = isBlogArticle ? null : page.seo;
const isTurnkeyRepair = !isBlogArticle && page.service.slug === "turnkey-repair";
const isPlastering = !isBlogArticle && page.service.slug === "plastering";
const serviceHero = isBlogArticle
  ? null
  : isPlastering
    ? {
        ...plasteringPage.hero,
        ...page.hero,
        mobileSubtitle: plasteringPage.hero.mobileSubtitle,
        mobileTags: plasteringPage.hero.mobileTags,
        rating: plasteringPage.hero.rating,
        image: {
          ...plasteringPage.hero.image,
          ...page.hero.image,
          mobile: plasteringPage.hero.image.mobile,
        },
      }
    : page.hero;
const heroRating = serviceHero?.rating;
const serviceQuiz = isBlogArticle ? null : getServiceQuiz(page.service.slug);
const cityInterlinkGroups = isBlogArticle ? [] : getCityInterlinkGroups(page.service.slug, city);
const servicePricingScripts = {
  plastering: "/scripts/features/pricing-table.js",
  "floor-screed": "/scripts/features/pricing-table-floor-screed.js",
  "airless-painting": "/scripts/features/pricing-table-airless-painting.js",
  "soft-roofing": "/scripts/features/pricing-table-soft-roofing.js",
  biozashchita: "/scripts/features/pricing-table-biozashchita.js",
};
const pricingScript =
  !isBlogArticle
    ? (page.runtime.pricingScript ?? servicePricingScripts[page.service.slug] ?? null)
    : null;
const plasteringPricingNote = {
  text: "Актуальные цены уточняйте у оператора:",
  label: "+7 (985) 135-49-91",
  href: "tel:+79851354991",
};
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: isBlogArticle ? [] : page.faq.map(item => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

{
  isBlogArticle ? (
    <BlogArticleBridge article={article} />
  ) : (
    <BaseLayout
      title={seo.title}
      description={seo.description}
      canonical={seo.canonical}
      ogTitle={seo.ogTitle}
      ogDescription={seo.ogDescription}
      ogImageAlt={seo.ogImageAlt}
      ogSiteName="ROSA - Ремонт под ключ"
      bodyClass={isPlastering ? "astro-service-page plastering-page" : "astro-service-page"}
      metrikaId={109562461}
      metrikaOptions={{
        ssr: true,
        webvisor: true,
        clickmap: true,
        ecommerce: "dataLayer",
        referrer: "document.referrer",
        url: "location.href",
        accurateTrackBounce: true,
        trackLinks: true,
      }}
      mainEntityId={`${seo.canonical}#service`}
      jsonLd={[
        page.jsonLd,
        breadcrumbJsonLd([
          { name: "Главная", url: "https://sk-rosa.ru/" },
          { name: page.service.name, url: `https://sk-rosa.ru/${page.service.slug}` },
          { name: city.name, url: seo.canonical },
        ]),
        faqJsonLd,
      ]}
    >
      <main>
        {isTurnkeyRepair ? (
          <>
            <TurnkeyRepairLegacyPage page={page} />
          </>
        ) : (
          <>
            <ServiceHero
              {...serviceHero}
              badges={isPlastering ? [] : serviceHero.badges}
              mobileCover={isPlastering}
            />
            {isPlastering && <PlasteringHeroBenefits items={serviceHero.badges} />}
            {isPlastering && <PlasteringRatings rating={heroRating} />}
            {serviceQuiz && (
              <ServiceQuiz
                client:load
                formSource={page.priceCalc.quizFormSource}
                questions={serviceQuiz.questions}
                serviceName={serviceQuiz.serviceName}
                title={page.priceCalc.quizTitle}
              />
            )}
            <ServiceAdvantages
              title={page.service.advantagesTitle}
              items={page.advantages}
              cta={{ href: "#pricing-table", label: page.service.advantagesCtaLabel }}
            />
            <ServiceTextBlock title={page.textBlock.title} subtitle={page.textBlock.subtitle}>
              {page.textBlock.paragraphs.map(paragraph => <p>{paragraph}</p>)}
            </ServiceTextBlock>
            <CityComplexes cityNameIn={city.nameIn} complexes={page.complexes} />
            <CityLocalContent content={page.localContent} />
            <ServiceSteps
              id={isPlastering ? "plastering-stages" : undefined}
              title={page.stages.title}
              subtitle={page.stages.subtitle}
              steps={page.stages.items}
              mobileSlider={isPlastering}
              cta={{
                title: "Готовы начать? Давайте обсудим ваш ремонт, оставьте заявку",
                href: "#contact-request",
                label: "Рассчитать стоимость",
              }}
            />
            <ServiceTaskList
              title={page.service.taskListTitle}
              items={page.taskList}
              image={page.hero.image}
            />
            {isPlastering && <PlasteringCasesSection {...page.workCases} />}
            <PricingSection
              title={page.service.pricingTitle}
              containerId={page.service.pricingContainerId}
              items={page.pricingTable ?? []}
              note={isPlastering ? plasteringPricingNote : undefined}
            />
            <PriceCalcSection
              data={page.priceCalc}
              showPlasteringEstimate={isPlastering ? false : undefined}
            />
            <ReviewsSection reviews={page.reviews} />
            <ContactRequest {...page.contact} />
            <FaqSection
              title="Ответы на частые вопросы"
              description={page.faqDescription}
              items={page.faq}
            />
            <ArticlesCarousel
              title="Полезные статьи о ремонте"
              articles={page.articles}
              moreHref="/blog"
              moreLabel="Посмотреть другие статьи"
            />
          </>
        )}
      </main>
      {
        isTurnkeyRepair && (
          <CityComplexes cityNameIn={city.nameIn} complexes={page.complexes} />
        )
      }
      <InternalLinksSection
        slot="before-footer"
        title={`Работы в ${city.nameIn} и рядом`}
        groups={cityInterlinkGroups}
      />
      {isTurnkeyRepair ? (
        <TurnkeyRepairLegacyRuntime
          slot="runtime"
          callBannerComments={page.runtime.callBannerComments}
          callBannerSource={page.runtime.callBannerSource}
        />
      ) : (
        <ServiceRuntime
          slot="runtime"
          callBannerComments={page.runtime.callBannerComments}
          callBannerSource={page.runtime.callBannerSource}
          pricingScript={pricingScript}
        />
      )}
    </BaseLayout>
  )
}
