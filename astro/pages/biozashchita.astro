---
import BaseLayout from "../components/BaseLayout.astro";
import ContactRequest from "../components/service/ContactRequest.astro";
import FaqSection from "../components/service/FaqSection.astro";
import InternalLinksSection from "../components/service/InternalLinksSection.astro";
import PriceCalcSection from "../components/service/PriceCalcSection.astro";
import PricingSection from "../components/service/PricingSection.astro";
import ReviewsSection from "../components/service/ReviewsSection.astro";
import ServiceAdvantages from "../components/service/ServiceAdvantages.astro";
import ServiceHero from "../components/service/ServiceHero.astro";
import ServiceQuiz from "../components/service/ServiceQuiz.jsx";
import ServiceRuntime from "../components/service/ServiceRuntime.astro";
import ServiceSteps from "../components/service/ServiceSteps.astro";
import ServiceTaskList from "../components/service/ServiceTaskList.astro";
import ServiceTextBlock from "../components/service/ServiceTextBlock.astro";
import ServiceTrustGrid from "../components/service/ServiceTrustGrid.astro";
import { biozashchitaJsonLd, biozashchitaPage } from "../data/biozashchita.js";
import { getServiceQuiz } from "../data/service-quizzes.js";
import { getServiceInterlinkGroups } from "../data/site-links.js";
import { breadcrumbJsonLd } from "../lib/seo.js";

const { seo } = biozashchitaPage;
const serviceQuiz = getServiceQuiz(biozashchitaPage.service.slug);
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: biozashchitaPage.faq.map(item => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
  ogImageAlt={seo.ogImageAlt}
  ogSiteName="ROSA - Ремонт под ключ"
  bodyClass="astro-service-page biozashchita-page"
  metrikaId={109562461}
  metrikaOptions={{
    ssr: true,
    webvisor: true,
    clickmap: true,
    ecommerce: "dataLayer",
    referrer: "document.referrer",
    url: "location.href",
    accurateTrackBounce: true,
    trackLinks: true,
  }}
  mainEntityId={`${seo.canonical}#service`}
  jsonLd={[
    biozashchitaJsonLd,
    breadcrumbJsonLd([
      { name: "Главная", url: "https://sk-rosa.ru/" },
      { name: "Огнебиозащита", url: seo.canonical },
    ]),
    faqJsonLd,
  ]}
>
  <main>
    <ServiceHero {...biozashchitaPage.hero} />
    <ServiceQuiz
      client:load
      formSource={biozashchitaPage.priceCalc.quizFormSource}
      questions={serviceQuiz.questions}
      serviceName={serviceQuiz.serviceName}
      title={biozashchitaPage.priceCalc.quizTitle}
    />
    <ServiceAdvantages
      title={biozashchitaPage.service.advantagesTitle}
      items={biozashchitaPage.advantages}
      cta={{ href: "#pricing-table", label: biozashchitaPage.service.advantagesCtaLabel }}
    />
    <ServiceTextBlock
      title={biozashchitaPage.textBlock.title}
      subtitle={biozashchitaPage.textBlock.subtitle}
    >
      {biozashchitaPage.textBlock.paragraphs.map(paragraph => <p>{paragraph}</p>)}
    </ServiceTextBlock>
    <ServiceSteps
      title={biozashchitaPage.stages.title}
      subtitle={biozashchitaPage.stages.subtitle}
      steps={biozashchitaPage.stages.items}
      cta={{
        title: "Нужна защита конструкций? Оставьте заявку на расчёт",
        href: "#contact-request",
        label: "Рассчитать стоимость",
      }}
    />
    <ServiceTaskList
      title={biozashchitaPage.service.taskListTitle}
      items={biozashchitaPage.taskList}
      image={biozashchitaPage.hero.image}
    />
    <ServiceTrustGrid
      title={biozashchitaPage.audiences.title}
      subtitle={biozashchitaPage.audiences.subtitle}
      items={biozashchitaPage.audiences.items}
    />
    <PricingSection
      title={biozashchitaPage.service.pricingTitle}
      containerId={biozashchitaPage.service.pricingContainerId}
      items={biozashchitaPage.pricingTable}
    />
    <PriceCalcSection data={biozashchitaPage.priceCalc} />
    <ReviewsSection reviews={biozashchitaPage.reviews} />
    <ContactRequest {...biozashchitaPage.contact} />
    <FaqSection
      title="Ответы на частые вопросы"
      description={biozashchitaPage.faqDescription}
      items={biozashchitaPage.faq}
    />
  </main>
  <InternalLinksSection
    slot="before-footer"
    title="Связанные разделы"
    groups={getServiceInterlinkGroups(biozashchitaPage.service.slug)}
  />
  <ServiceRuntime
    slot="runtime"
    pricingScript={biozashchitaPage.runtime.pricingScript}
    callBannerComments={biozashchitaPage.runtime.callBannerComments}
    callBannerSource={biozashchitaPage.runtime.callBannerSource}
  />
</BaseLayout>
