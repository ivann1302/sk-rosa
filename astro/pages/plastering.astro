---
import BaseLayout from "../components/BaseLayout.astro";
import ArticlesCarousel from "../components/service/ArticlesCarousel.astro";
import ContactRequest from "../components/service/ContactRequest.astro";
import FaqSection from "../components/service/FaqSection.astro";
import PlasteringCasesSection from "../components/service/PlasteringCasesSection.astro";
import PlasteringQuiz from "../components/service/PlasteringQuiz.jsx";
import PriceCalcSection from "../components/service/PriceCalcSection.astro";
import ReviewsSection from "../components/service/ReviewsSection.astro";
import ServiceAdvantages from "../components/service/ServiceAdvantages.astro";
import ServiceHero from "../components/service/ServiceHero.astro";
import ServiceRuntime from "../components/service/ServiceRuntime.astro";
import ServiceSteps from "../components/service/ServiceSteps.astro";
import ServiceTaskList from "../components/service/ServiceTaskList.astro";
import ServiceTextBlock from "../components/service/ServiceTextBlock.astro";
import { plasteringJsonLd, plasteringPage } from "../data/plastering.js";
import { breadcrumbJsonLd } from "../lib/seo.js";

const { seo } = plasteringPage;
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: plasteringPage.faq.map(item => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
  ogImageAlt={seo.ogImageAlt}
  ogSiteName="ROSA - Ремонт под ключ"
  bodyClass="astro-service-page"
  metrikaId={109562461}
  metrikaOptions={{
    ssr: true,
    webvisor: true,
    clickmap: true,
    ecommerce: "dataLayer",
    referrer: "document.referrer",
    url: "location.href",
    accurateTrackBounce: true,
    trackLinks: true,
  }}
  jsonLd={[
    plasteringJsonLd,
    breadcrumbJsonLd([
      { name: "Главная", url: "https://sk-rosa.ru/" },
      { name: "Штукатурные работы", url: seo.canonical },
    ]),
    faqJsonLd,
  ]}
>
  <main>
    <ServiceHero {...plasteringPage.hero} />
    <ServiceAdvantages
      title="Преимущества штукатурных работ"
      items={plasteringPage.advantages}
      cta={{ href: "#plastering-calculator", label: "Рассчитать штукатурку" }}
    />
    <PlasteringQuiz client:load />
    <ServiceTextBlock
      title="Механизированная штукатурка стен под ключ в Москве и МО"
      subtitle="Гипсовая и цементная штукатурка - от замера до сдачи под чистовую отделку"
    >
      <p>
        Основные наши заказчики - владельцы <strong>квартир в новостройках, частных домов и
        коммерческих объектов</strong>: коттеджей, офисов, магазинов и небольших производств.
        Машинная подача смеси через штукатурную станцию даёт скорость до <strong>200 м² за
        смену</strong> - выгодно на крупных объёмах.
      </p>
      <p>
        <strong>Гипсовая штукатурка</strong> - выбор для квартир, офисов и спален: даёт гладкую
        поверхность под покраску и обои, дышит, не нагружает перекрытия. <strong>Цементная
        штукатурка</strong> прочнее и не боится влаги - её ставим в ванных, кухнях, подвалах,
        гаражах и на фасадах.
      </p>
      <p>
        Работаем штукатурными станциями PFT и Kaleta: смесь готовим прямо у объекта и подаём
        шлангом на этаж - без вёдер и грязи в подъезде. Геометрию выводим <strong>строго по
        маякам</strong>, а объём, сроки и цену фиксируем в договоре до начала работ.
      </p>
    </ServiceTextBlock>
    <ServiceSteps
      title={plasteringPage.stages.title}
      subtitle={plasteringPage.stages.subtitle}
      steps={plasteringPage.stages.items}
      cta={{
        title: "Готовы начать? Давайте обсудим ваш ремонт, оставьте заявку",
        href: "#contact-request",
        label: "Рассчитать стоимость",
      }}
    />
    <ServiceTaskList
      title="Штукатурим любые стены - под любые задачи"
      items={plasteringPage.taskList}
      image={plasteringPage.hero.image}
    />
    <PlasteringCasesSection {...plasteringPage.workCases} />
    <PriceCalcSection data={plasteringPage.priceCalc} showPlasteringEstimate={false} />
    <ReviewsSection reviews={plasteringPage.reviews} />
    <ContactRequest {...plasteringPage.contact} />
    <FaqSection
      title="Ответы на частые вопросы"
      description={plasteringPage.faqDescription}
      items={plasteringPage.faq}
    />
    <ArticlesCarousel
      title="Полезные статьи о ремонте"
      articles={plasteringPage.articles}
      moreHref="/blog"
      moreLabel="Посмотреть другие статьи"
    />
  </main>
  <ServiceRuntime slot="runtime" pricingScript={null} />
</BaseLayout>
