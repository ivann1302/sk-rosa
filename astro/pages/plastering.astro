---
import BaseLayout from "../components/BaseLayout.astro";
import ArticlesCarousel from "../components/service/ArticlesCarousel.astro";
import ContactRequest from "../components/service/ContactRequest.astro";
import FaqSection from "../components/service/FaqSection.astro";
import InternalLinksSection from "../components/service/InternalLinksSection.astro";
import PlasteringHeroBenefits from "../components/service/PlasteringHeroBenefits.astro";
import PlasteringRatings from "../components/service/PlasteringRatings.astro";
import PlasteringCasesSection from "../components/service/PlasteringCasesSection.astro";
import PriceCalcSection from "../components/service/PriceCalcSection.astro";
import PricingSection from "../components/service/PricingSection.astro";
import ReviewsSection from "../components/service/ReviewsSection.astro";
import ServiceAdvantages from "../components/service/ServiceAdvantages.astro";
import ServiceHero from "../components/service/ServiceHero.astro";
import ServiceQuiz from "../components/service/ServiceQuiz.jsx";
import ServiceRuntime from "../components/service/ServiceRuntime.astro";
import ServiceSteps from "../components/service/ServiceSteps.astro";
import ServiceTaskList from "../components/service/ServiceTaskList.astro";
import ServiceTextBlock from "../components/service/ServiceTextBlock.astro";
import { plasteringJsonLd, plasteringPage } from "../data/plastering.js";
import { getServiceQuiz } from "../data/service-quizzes.js";
import { getServiceInterlinkGroups } from "../data/site-links.js";
import { breadcrumbJsonLd } from "../lib/seo.js";

const { seo } = plasteringPage;
const serviceQuiz = getServiceQuiz(plasteringPage.priceCalc.serviceSlug);
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: plasteringPage.faq.map(item => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
  ogImageAlt={seo.ogImageAlt}
  ogSiteName="ROSA - Ремонт под ключ"
  bodyClass="astro-service-page plastering-page"
  metrikaId={109562461}
  metrikaOptions={{
    ssr: true,
    webvisor: true,
    clickmap: true,
    ecommerce: "dataLayer",
    referrer: "document.referrer",
    url: "location.href",
    accurateTrackBounce: true,
    trackLinks: true,
  }}
  mainEntityId={`${seo.canonical}#service`}
  jsonLd={[
    plasteringJsonLd,
    breadcrumbJsonLd([
      { name: "Главная", url: "https://sk-rosa.ru/" },
      { name: "Штукатурные работы", url: seo.canonical },
    ]),
    faqJsonLd,
  ]}
>
  <main>
    <ServiceHero {...plasteringPage.hero} badges={[]} mobileCover />
    <PlasteringHeroBenefits items={plasteringPage.hero.badges} />
    <PlasteringRatings rating={plasteringPage.hero.rating} />
    <ServiceQuiz
      client:load
      formSource={plasteringPage.priceCalc.quizFormSource}
      questions={serviceQuiz.questions}
      serviceName={serviceQuiz.serviceName}
      title={plasteringPage.priceCalc.quizTitle}
    />
    <ServiceAdvantages
      title="Преимущества штукатурных работ"
      items={plasteringPage.advantages}
      cta={{ href: "#plastering-calculator", label: "Рассчитать штукатурку" }}
    />
    <ServiceTextBlock
      id="plastering-service-details"
      title={plasteringPage.textBlock.title}
      subtitle={plasteringPage.textBlock.subtitle}
      cta={plasteringPage.textBlock.cta}
    >
      <ul class="service-text-block__check-list">
        {
          plasteringPage.textBlock.benefits.map(benefit => (
            <li>
              <svg
                class="service-text-block__check-icon"
                viewBox="0 0 24 24"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="m5 12 4 4 10-10"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
              <span>{benefit}</span>
            </li>
          ))
        }
      </ul>
    </ServiceTextBlock>
    <ServiceSteps
      id="plastering-stages"
      title={plasteringPage.stages.title}
      subtitle={plasteringPage.stages.subtitle}
      steps={plasteringPage.stages.items}
      mobileSlider
      cta={{
        title: "Готовы начать? Давайте обсудим ваш ремонт, оставьте заявку",
        href: "#contact-request",
        label: "Рассчитать стоимость",
      }}
    />
    <ServiceTaskList
      title="Штукатурим любые стены - под любые задачи"
      items={plasteringPage.taskList}
      image={plasteringPage.hero.image}
    />
    <PlasteringCasesSection {...plasteringPage.workCases} />
    <PricingSection
      title={plasteringPage.service.pricingTitle}
      containerId={plasteringPage.service.pricingContainerId}
      items={plasteringPage.pricingTable}
      note={{
        text: "Актуальные цены уточняйте у оператора:",
        label: "+7 (985) 135-49-91",
        href: "tel:+79851354991",
      }}
    />
    <PriceCalcSection data={plasteringPage.priceCalc} showPlasteringEstimate={false} />
    <ReviewsSection reviews={plasteringPage.reviews} />
    <ContactRequest {...plasteringPage.contact} />
    <FaqSection
      title="Ответы на частые вопросы"
      description={plasteringPage.faqDescription}
      items={plasteringPage.faq}
    />
    <ArticlesCarousel
      title="Полезные статьи о ремонте"
      articles={plasteringPage.articles}
      moreHref="/blog"
      moreLabel="Посмотреть другие статьи"
    />
  </main>
  <InternalLinksSection
    slot="before-footer"
    title="Связанные разделы"
    groups={getServiceInterlinkGroups("plastering")}
  />
  <ServiceRuntime slot="runtime" pricingScript={plasteringPage.runtime.pricingScript} />
</BaseLayout>
