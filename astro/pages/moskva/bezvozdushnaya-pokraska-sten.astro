---
import BaseLayout from "../../components/BaseLayout.astro";
import ContactRequest from "../../components/service/ContactRequest.astro";
import FaqSection from "../../components/service/FaqSection.astro";
import PricingSection from "../../components/service/PricingSection.astro";
import ServiceHero from "../../components/service/ServiceHero.astro";
import ServiceRuntime from "../../components/service/ServiceRuntime.astro";
import ServiceTextBlock from "../../components/service/ServiceTextBlock.astro";
import "../../styles/pages/airless-commercial.scss";
import {
  airlessPaintingWallsJsonLd,
  airlessPaintingWallsPage,
} from "../../data/airless-painting-walls.js";
import { breadcrumbJsonLd } from "../../lib/seo.js";

const { seo } = airlessPaintingWallsPage;
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: airlessPaintingWallsPage.faq.map(item => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
  ogImageAlt={seo.ogImageAlt}
  ogSiteName="ROSA - Ремонт под ключ"
  bodyClass="astro-service-page airless-walls-page"
  metrikaId={109562461}
  metrikaOptions={{
    ssr: true,
    webvisor: true,
    clickmap: true,
    ecommerce: "dataLayer",
    referrer: "document.referrer",
    url: "location.href",
    accurateTrackBounce: true,
    trackLinks: true,
  }}
  mainEntityId={`${seo.canonical}#service`}
  jsonLd={[
    airlessPaintingWallsJsonLd,
    breadcrumbJsonLd([
      { name: "Главная", url: "https://sk-rosa.ru/" },
      { name: "Безвоздушная покраска", url: "https://sk-rosa.ru/airless-painting" },
      { name: "Покраска стен", url: seo.canonical },
    ]),
    faqJsonLd,
  ]}
>
  <main>
    <ServiceHero {...airlessPaintingWallsPage.hero} />

    <ServiceTextBlock
      title={airlessPaintingWallsPage.intro.title}
      subtitle={airlessPaintingWallsPage.intro.subtitle}
    >
      <p><strong>{airlessPaintingWallsPage.directAnswer}</strong></p>
      {airlessPaintingWallsPage.intro.paragraphs.map(paragraph => <p>{paragraph}</p>)}
    </ServiceTextBlock>

    <section class="airless-walls-fit">
      <div class="airless-walls-fit__container">
        <div class="airless-walls-fit__header">
          <h2>Какие стены красим</h2>
          <p>
            Страница про стены, поэтому не смешиваем сюда фасады, потолки и металл. Ниже —
            ситуации, где аппарат обычно даёт понятную экономию времени и аккуратный результат.
          </p>
        </div>
        <div class="airless-walls-fit__grid">
          {airlessPaintingWallsPage.fit.map(item => <div class="airless-walls-fit__item">{item}</div>)}
        </div>
      </div>
    </section>

    <section class="airless-walls-detail">
      <div class="airless-walls-detail__container">
        <div class="airless-walls-detail__column">
          <h2>Что проверяем заранее</h2>
          <ul>
            {airlessPaintingWallsPage.notFit.map(item => <li>{item}</li>)}
          </ul>
        </div>
        <div class="airless-walls-detail__column">
          <h2>Что меняет смету</h2>
          <ul>
            {airlessPaintingWallsPage.estimateFactors.map(item => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </section>

    <section class="airless-walls-process">
      <div class="airless-walls-process__container">
        <h2>Как работаем со стенами</h2>
        <div class="airless-walls-process__list">
          {
            airlessPaintingWallsPage.process.map((item, index) => (
              <article class="airless-walls-process__item">
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <PricingSection
      title="Цена покраски стен"
      containerId="pricing-table-airless-painting-walls"
      items={airlessPaintingWallsPage.pricing}
    />

    <section class="airless-walls-note">
      <div class="airless-walls-note__container">
        <p>{airlessPaintingWallsPage.priceNote}</p>
      </div>
    </section>

    <ContactRequest {...airlessPaintingWallsPage.contact} />

    <FaqSection
      title="Вопросы перед стартом"
      description={airlessPaintingWallsPage.faqDescription}
      items={airlessPaintingWallsPage.faq}
    />

  </main>

  <ServiceRuntime
    slot="runtime"
    pricingScript={null}
    callBannerComments={airlessPaintingWallsPage.runtime.callBannerComments}
    callBannerSource={airlessPaintingWallsPage.runtime.callBannerSource}
  />
</BaseLayout>
