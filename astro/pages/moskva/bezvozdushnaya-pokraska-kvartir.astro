---
import BaseLayout from "../../components/BaseLayout.astro";
import ContactRequest from "../../components/service/ContactRequest.astro";
import FaqSection from "../../components/service/FaqSection.astro";
import PricingSection from "../../components/service/PricingSection.astro";
import ServiceHero from "../../components/service/ServiceHero.astro";
import ServiceRuntime from "../../components/service/ServiceRuntime.astro";
import ServiceTextBlock from "../../components/service/ServiceTextBlock.astro";
import "../../styles/pages/airless-commercial.scss";
import {
  airlessPaintingApartmentsJsonLd,
  airlessPaintingApartmentsPage,
} from "../../data/airless-painting-apartments.js";
import { breadcrumbJsonLd } from "../../lib/seo.js";

const { seo } = airlessPaintingApartmentsPage;
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: airlessPaintingApartmentsPage.faq.map(item => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
  ogImageAlt={seo.ogImageAlt}
  ogSiteName="ROSA - Ремонт под ключ"
  bodyClass="astro-service-page airless-walls-page"
  metrikaId={109562461}
  metrikaOptions={{
    ssr: true,
    webvisor: true,
    clickmap: true,
    ecommerce: "dataLayer",
    referrer: "document.referrer",
    url: "location.href",
    accurateTrackBounce: true,
    trackLinks: true,
  }}
  mainEntityId={`${seo.canonical}#service`}
  jsonLd={[
    airlessPaintingApartmentsJsonLd,
    breadcrumbJsonLd([
      { name: "Главная", url: "https://sk-rosa.ru/" },
      { name: "Безвоздушная покраска", url: "https://sk-rosa.ru/airless-painting" },
      { name: "Покраска квартиры", url: seo.canonical },
    ]),
    faqJsonLd,
  ]}
>
  <main>
    <ServiceHero {...airlessPaintingApartmentsPage.hero} />

    <ServiceTextBlock
      title={airlessPaintingApartmentsPage.intro.title}
      subtitle={airlessPaintingApartmentsPage.intro.subtitle}
    >
      <p><strong>{airlessPaintingApartmentsPage.directAnswer}</strong></p>
      {airlessPaintingApartmentsPage.intro.paragraphs.map(paragraph => <p>{paragraph}</p>)}
    </ServiceTextBlock>

    <section class="airless-walls-fit">
      <div class="airless-walls-fit__container">
        <div class="airless-walls-fit__header">
          <h2>Какие квартиры берём в работу</h2>
          <p>
            В квартире аппарат имеет смысл, когда нужно равномерно покрасить несколько помещений,
            а не один небольшой участок.
          </p>
        </div>
        <div class="airless-walls-fit__grid">
          {
            airlessPaintingApartmentsPage.fit.map(item => (
              <div class="airless-walls-fit__item">{item}</div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="airless-walls-detail">
      <div class="airless-walls-detail__container">
        <div class="airless-walls-detail__column">
          <h2>Что проверяем заранее</h2>
          <ul>
            {airlessPaintingApartmentsPage.notFit.map(item => <li>{item}</li>)}
          </ul>
        </div>
        <div class="airless-walls-detail__column">
          <h2>Что влияет на цену</h2>
          <ul>
            {airlessPaintingApartmentsPage.estimateFactors.map(item => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </section>

    <section class="airless-walls-process">
      <div class="airless-walls-process__container">
        <h2>Как работаем в квартире</h2>
        <div class="airless-walls-process__list">
          {
            airlessPaintingApartmentsPage.process.map((item, index) => (
              <article class="airless-walls-process__item">
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <PricingSection
      title="Ориентиры по цене"
      containerId="pricing-table-airless-painting-apartments"
      items={airlessPaintingApartmentsPage.pricing}
    />

    <section class="airless-walls-note">
      <div class="airless-walls-note__container">
        <p>{airlessPaintingApartmentsPage.priceNote}</p>
      </div>
    </section>

    <ContactRequest {...airlessPaintingApartmentsPage.contact} />

    <FaqSection
      title="Вопросы перед стартом"
      description={airlessPaintingApartmentsPage.faqDescription}
      items={airlessPaintingApartmentsPage.faq}
    />
  </main>

  <ServiceRuntime
    slot="runtime"
    pricingScript={null}
    callBannerComments={airlessPaintingApartmentsPage.runtime.callBannerComments}
    callBannerSource={airlessPaintingApartmentsPage.runtime.callBannerSource}
  />
</BaseLayout>
