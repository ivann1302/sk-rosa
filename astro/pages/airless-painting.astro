---
import BaseLayout from "../components/BaseLayout.astro";
import ArticlesCarousel from "../components/service/ArticlesCarousel.astro";
import ContactRequest from "../components/service/ContactRequest.astro";
import FaqSection from "../components/service/FaqSection.astro";
import InternalLinksSection from "../components/service/InternalLinksSection.astro";
import PriceCalcSection from "../components/service/PriceCalcSection.astro";
import PricingSection from "../components/service/PricingSection.astro";
import ReviewsSection from "../components/service/ReviewsSection.astro";
import ServiceAdvantages from "../components/service/ServiceAdvantages.astro";
import ServiceHero from "../components/service/ServiceHero.astro";
import ServiceQuiz from "../components/service/ServiceQuiz.jsx";
import ServiceRuntime from "../components/service/ServiceRuntime.astro";
import ServiceSteps from "../components/service/ServiceSteps.astro";
import ServiceTaskList from "../components/service/ServiceTaskList.astro";
import ServiceTextBlock from "../components/service/ServiceTextBlock.astro";
import { airlessPaintingJsonLd, airlessPaintingPage } from "../data/airless-painting.js";
import { getServiceQuiz } from "../data/service-quizzes.js";
import { getServiceInterlinkGroups } from "../data/site-links.js";
import { breadcrumbJsonLd } from "../lib/seo.js";

const { seo } = airlessPaintingPage;
const serviceQuiz = getServiceQuiz(airlessPaintingPage.service.slug);
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: airlessPaintingPage.faq.map(item => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
  ogImageAlt={seo.ogImageAlt}
  ogSiteName="ROSA - Ремонт под ключ"
  bodyClass="astro-service-page"
  metrikaId={109562461}
  metrikaOptions={{
    ssr: true,
    webvisor: true,
    clickmap: true,
    ecommerce: "dataLayer",
    referrer: "document.referrer",
    url: "location.href",
    accurateTrackBounce: true,
    trackLinks: true,
  }}
  jsonLd={[
    airlessPaintingJsonLd,
    breadcrumbJsonLd([
      { name: "Главная", url: "https://sk-rosa.ru/" },
      { name: "Безвоздушная покраска", url: seo.canonical },
    ]),
    faqJsonLd,
  ]}
>
  <main>
    <ServiceHero {...airlessPaintingPage.hero} />
    <ServiceQuiz
      client:load
      formSource={airlessPaintingPage.priceCalc.quizFormSource}
      questions={serviceQuiz.questions}
      serviceName={serviceQuiz.serviceName}
      title={airlessPaintingPage.priceCalc.quizTitle}
    />
    <ServiceAdvantages
      title={airlessPaintingPage.service.advantagesTitle}
      items={airlessPaintingPage.advantages}
      cta={{ href: "#pricing-table", label: airlessPaintingPage.service.advantagesCtaLabel }}
    />
    <ServiceTextBlock
      title={airlessPaintingPage.textBlock.title}
      subtitle={airlessPaintingPage.textBlock.subtitle}
    >
      {airlessPaintingPage.textBlock.paragraphs.map(paragraph => <p>{paragraph}</p>)}
    </ServiceTextBlock>
    <ServiceSteps
      title={airlessPaintingPage.stages.title}
      subtitle={airlessPaintingPage.stages.subtitle}
      steps={airlessPaintingPage.stages.items}
      cta={{
        title: "Готовы начать? Давайте обсудим ваш ремонт, оставьте заявку",
        href: "#contact-request",
        label: "Рассчитать стоимость",
      }}
    />
    <ServiceTaskList
      title={airlessPaintingPage.service.taskListTitle}
      items={airlessPaintingPage.taskList}
      image={airlessPaintingPage.hero.image}
    />
    <PricingSection
      title={airlessPaintingPage.service.pricingTitle}
      containerId={airlessPaintingPage.service.pricingContainerId}
    />
    <PriceCalcSection data={airlessPaintingPage.priceCalc} />
    <ReviewsSection reviews={airlessPaintingPage.reviews} />
    <ContactRequest {...airlessPaintingPage.contact} />
    <FaqSection
      title="Ответы на частые вопросы"
      description={airlessPaintingPage.faqDescription}
      items={airlessPaintingPage.faq}
    />
    <ArticlesCarousel
      title="Полезные статьи о ремонте"
      articles={airlessPaintingPage.articles}
      moreHref="/blog"
      moreLabel="Посмотреть другие статьи"
    />
  </main>
  <InternalLinksSection
    slot="before-footer"
    title="Связанные разделы"
    groups={getServiceInterlinkGroups(airlessPaintingPage.service.slug)}
  />
  <ServiceRuntime
    slot="runtime"
    pricingScript={airlessPaintingPage.runtime.pricingScript}
    callBannerComments={airlessPaintingPage.runtime.callBannerComments}
    callBannerSource={airlessPaintingPage.runtime.callBannerSource}
  />
</BaseLayout>
