---
import BaseLayout from "../components/BaseLayout.astro";
import ArticlesCarousel from "../components/service/ArticlesCarousel.astro";
import ContactRequest from "../components/service/ContactRequest.astro";
import FaqSection from "../components/service/FaqSection.astro";
import PriceCalcSection from "../components/service/PriceCalcSection.astro";
import PricingSection from "../components/service/PricingSection.astro";
import ReviewsSection from "../components/service/ReviewsSection.astro";
import ServiceAdvantages from "../components/service/ServiceAdvantages.astro";
import ServiceHero from "../components/service/ServiceHero.astro";
import ServiceRuntime from "../components/service/ServiceRuntime.astro";
import ServiceSteps from "../components/service/ServiceSteps.astro";
import ServiceTaskList from "../components/service/ServiceTaskList.astro";
import ServiceTextBlock from "../components/service/ServiceTextBlock.astro";
import { softRoofingJsonLd, softRoofingPage } from "../data/soft-roofing.js";
import { breadcrumbJsonLd } from "../lib/seo.js";

const { seo } = softRoofingPage;
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: softRoofingPage.faq.map(item => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
  ogImageAlt={seo.ogImageAlt}
  ogSiteName="ROSA - Ремонт под ключ"
  bodyClass="astro-service-page"
  metrikaId={109562461}
  metrikaOptions={{
    ssr: true,
    webvisor: true,
    clickmap: true,
    ecommerce: "dataLayer",
    referrer: "document.referrer",
    url: "location.href",
    accurateTrackBounce: true,
    trackLinks: true,
  }}
  jsonLd={[
    softRoofingJsonLd,
    breadcrumbJsonLd([
      { name: "Главная", url: "https://sk-rosa.ru/" },
      { name: "Мягкая кровля", url: seo.canonical },
    ]),
    faqJsonLd,
  ]}
>
  <main>
    <ServiceHero {...softRoofingPage.hero} />
    <ServiceAdvantages
      title={softRoofingPage.service.advantagesTitle}
      items={softRoofingPage.advantages}
      cta={{ href: "#pricing-table", label: softRoofingPage.service.advantagesCtaLabel }}
    />
    <ServiceTextBlock title={softRoofingPage.textBlock.title} subtitle={softRoofingPage.textBlock.subtitle}>
      {softRoofingPage.textBlock.paragraphs.map(paragraph => <p>{paragraph}</p>)}
    </ServiceTextBlock>
    <ServiceSteps
      title={softRoofingPage.stages.title}
      subtitle={softRoofingPage.stages.subtitle}
      steps={softRoofingPage.stages.items}
      cta={{
        title: "Готовы начать? Оставьте заявку на расчёт",
        href: "#contact-request",
        label: "Рассчитать стоимость",
      }}
    />
    <ServiceTaskList
      title={softRoofingPage.service.taskListTitle}
      items={softRoofingPage.taskList}
      image={softRoofingPage.hero.image}
    />
    <PricingSection
      title={softRoofingPage.service.pricingTitle}
      containerId={softRoofingPage.service.pricingContainerId}
    />
    <PriceCalcSection data={softRoofingPage.priceCalc} />
    <ReviewsSection reviews={softRoofingPage.reviews} />
    <ContactRequest {...softRoofingPage.contact} />
    <FaqSection
      title="Ответы на частые вопросы"
      description={softRoofingPage.faqDescription}
      items={softRoofingPage.faq}
    />
    <ArticlesCarousel
      title="Полезные статьи о ремонте"
      articles={softRoofingPage.articles}
      moreHref="/blog"
      moreLabel="Посмотреть другие статьи"
    />
  </main>
  <ServiceRuntime
    slot="runtime"
    pricingScript={softRoofingPage.runtime.pricingScript}
    callBannerComments={softRoofingPage.runtime.callBannerComments}
    callBannerSource={softRoofingPage.runtime.callBannerSource}
  />
</BaseLayout>
